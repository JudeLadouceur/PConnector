  m_Script: {fileID: 11500000, guid: 5e326000ad0ca544cb511dc2c304f4cc, type: 3}
  m_Name: DAY 5 CALL 1 MRS. PERKINS EMERGENCY A
  m_EditorClassIdentifier: 
  lines:
  - NewSpeakerName: 4
    dialogue: "Maplegrove emergency line. What\u2019s your situation?"
  - NewSpeakerName: 1
    dialogue: "Hello, dear. This is Mrs. Perkins. I apologize, as this isn\u2019t
      much of an emergency, but I need to cancel some appointments I have with the
      health centre."
  - NewSpeakerName: 4
    dialogue: Of course, Mrs. Perkins. This would be the line to do it. Which appointments
      do you need cancelled? Can I reschedule them for you?
  - NewSpeakerName: 1
    dialogue: "That won\u2019t be necessary, dear. You see, I\u2019m moving out of
      town, and I\u2019ll be setting up my appointments elsewhere."
  - NewSpeakerName: 4
    dialogue: "You\u2019re\u2026 leaving? I had no idea. Well, good luck to you,
      Mrs. Perkins. I hope things work out for you."
  - NewSpeakerName: 1
    dialogue: "Thank you dear. I\u2019m sure things will go fine. I\u2019m just looking
      to get things ready."
  - NewSpeakerName: 4
    dialogue: "Well I\u2019ve put it into the system just now, Mrs. Perkins. All
      your upcoming appointments have been cancelled, and you\u2019re all good to
      go."
  - NewSpeakerName: 1
    dialogue: "Thank you so much, dear. You\u2019ve been a great help. Though I must
      be going now, I have much to do to get ready."
  - NewSpeakerName: 4
    dialogue: Of course, Mrs. Perkins. Safe travels.
  - NewSpeakerName: 1
    dialogue: "You have a good day dear, it\u2019s been wonderful."
